{
  "name": "lime-bot",
  "version": "1.0.11",
  "description": "LimeBot - The elegant and powerful agentic bot",
  "main": "bin/cli.js",
  "bin": {
    "lime-bot": "bin/cli.js",
    "limebot": "bin/cli.js"
  },
  "scripts": {
    "lime-bot": "node bin/cli.js",
    "limebot": "node bin/cli.js",
    "start": "node bin/cli.js start",
    "start:quick": "node bin/cli.js start --quick",
    "status": "node bin/cli.js status",
    "doctor": "node bin/cli.js doctor",
    "stop": "node bin/cli.js stop",
    "logs": "node bin/cli.js logs",
    "skill": "node bin/cli.js skill",
    "install-browser": "node bin/cli.js install-browser",
    "web:dev": "cd web && npm run dev -- --host 0.0.0.0",
    "backend:dev": "python main.py",
    "extension:dev": "npm run dev --workspace extension",
    "extension:build": "npm run build --workspace extension",
    "test:cli": "node --test tests-js/*.test.js"
  },
  "workspaces": [
    "web",
    "bridge",
    "extension"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.2"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
