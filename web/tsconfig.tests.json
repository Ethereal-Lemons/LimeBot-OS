{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": ".test-dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "src/lib/chat-state.ts",
    "src/lib/agent-readiness.ts",
    "src/lib/markdown-code.ts",
    "src/lib/setup-state.ts",
    "tests/agent-readiness.test.ts",
    "tests/chat-state.test.ts",
    "tests/markdown-code.test.ts",
    "tests/setup-state.test.ts"
  ]
}
