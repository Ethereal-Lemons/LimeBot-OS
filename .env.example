# --- LLM Configuration ---
# Authentication Mode: 'api_key' or 'adc' (Application Default Credentials)
LLM_AUTH_MODE=api_key

# Model to use (e.g., gemini/gemini-2.0-flash, openai/gpt-5.5, ollama/llama3)
LLM_MODEL=gemini/gemini-2.0-flash
# Optional ordered fallback models if the primary provider/model is unavailable
# LLM_FALLBACK_MODELS=openai/gpt-5.4-mini,anthropic/claude-3-5-haiku-latest

# API Keys (Required if auth_mode is 'api_key' and not using a local provider)
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# XAI_API_KEY=your_xai_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# MOONSHOT_API_KEY=your_moonshot_api_key_here
# NVIDIA_API_KEY=your_nvidia_api_key_here

# --- Video Analysis (optional) ---
# Caption-less audio is sent to OpenAI Whisper only when this is explicitly on.
VIDEO_WHISPER_ENABLED=false
# Runtime aliases still work if you already use them:
# KIMI_API_KEY=your_moonshot_api_key_here

# Local LLM Support (Ollama / LocalAI)
# LLM_BASE_URL=http://localhost:11434/v1

# --- Discord Configuration ---
# Toggle Discord integration (true/false)
ENABLE_DISCORD=true
# Bot Token from Discord Developer Portal
DISCORD_TOKEN=

# Control who can interact with the bot
# Comma-separated User IDs (leave empty to allow all)
DISCORD_ALLOW_FROM=
# Comma-separated Channel IDs (leave empty to allow all)
DISCORD_ALLOW_CHANNELS=

# Bot Presence
DISCORD_ACTIVITY_TYPE=playing
DISCORD_ACTIVITY_TEXT=LimeBot
DISCORD_STATUS=online

# --- WhatsApp Configuration ---
# Enable/Disable WhatsApp integration (true/false)
ENABLE_WHATSAPP=false
# URL for the WhatsApp Bridge
WHATSAPP_BRIDGE_URL=ws://localhost:3000
# Comma-separated Phone Numbers allowed to interact (e.g. 1234567890@s.whatsapp.net)
WHATSAPP_ALLOW_FROM=

# --- Telegram Configuration ---
# Enable/Disable Telegram integration (true/false)
ENABLE_TELEGRAM=false
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Optional Telegram Bot API base URL
TELEGRAM_API_BASE=https://api.telegram.org
# Comma-separated Telegram user IDs allowed to interact (leave empty to allow all)
TELEGRAM_ALLOW_FROM=
# Optional comma-separated chat IDs allowed to receive/send messages
TELEGRAM_ALLOW_CHATS=
# Long-poll timeout in seconds
TELEGRAM_POLL_TIMEOUT=30

# --- Advanced Personalization ---
# Allow the bot to adjust its personality and affinity per user (true/false)
ENABLE_DYNAMIC_PERSONALITY=false
# Comma-separated list of usernames to track in personality profiles
# PERSONALITY_WHITELIST=user1,user2

# --- Security / Sandbox ---
# Allowed paths for the bot to read/write files (comma-separated)
ALLOWED_PATHS=./persona,./logs,./temp
# Optional: password for the web dashboard
APP_API_KEY=

# --- Automation & Limits ---
# Enable autonomous mode (bypass confirmation prompts) - USE WITH CAUTION
AUTONOMOUS_MODE=false
# Preferred approval policy: manual, session, review, or autonomous.
# When set, this takes precedence over the legacy AUTONOMOUS_MODE toggle.
APPROVAL_POLICY_PROFILE=manual
# Allow dangerous shell commands (bypass character filtering) - HIGH RISK
ALLOW_UNSAFE_COMMANDS=false
# Maximum tool call loops before forcing a stop
MAX_ITERATIONS=30
# AI harness latency profile. "fast" is the default: 80ms Auto-RAG budget,
# request-specific tool schemas, and no tool schema for clearly casual turns.
# Set "balanced" for the compatibility profile (200ms Auto-RAG and full schema).
LIMEBOT_AI_HARNESS_MODE=fast
LIMEBOT_FAST_RAG_TIMEOUT=0.08
LIMEBOT_BALANCED_RAG_TIMEOUT=0.2
LIMEBOT_FAST_DISABLE_TOOLS_FOR_CASUAL=true
# Optional legacy override. Leave empty to follow the selected harness mode.
LIMEBOT_ENABLE_TOOL_SHORTLIST=
# Timeout for command execution (seconds)
COMMAND_TIMEOUT=0
# Timeout for unresponsive commands (seconds)
STALL_TIMEOUT=0
# Backend API/WebSocket port
WEB_PORT=8000
# Backend bind host. Defaults to 127.0.0.1 (localhost only). To reach LimeBot
# from another device on your LAN, set WEB_HOST=0.0.0.0 AND set APP_API_KEY:
# a non-loopback bind without an API key is refused and forced back to 127.0.0.1.
WEB_HOST=127.0.0.1
# Docker Compose sets this only while the backend is reachable exclusively
# through the internal Nginx gateway. Never enable it with a published backend
# port unless APP_API_KEY is also configured.
LIMEBOT_TRUSTED_PROXY_ONLY=false

# Docker build profiles. Leave empty/0 for the core image.
LIMEBOT_DOCKER_FEATURES=
LIMEBOT_DOCKER_INSTALL_BROWSER=0
LIMEBOT_DOCKER_BIND_HOST=127.0.0.1
LIMEBOT_FRONTEND_PORT=3000
# WhatsApp bridge bind host (defaults to 127.0.0.1). Override for LAN access.
# BRIDGE_HOST=127.0.0.1
# Frontend dev server port (used by `limebot start`)
FRONTEND_PORT=5173

# --- Web Search (optional, hybrid) ---
# Provider selection: auto (default), tavily, brave, serpapi, duckduckgo, or scrape.
# "auto" uses any configured API key by priority, then falls back to the keyless
# DuckDuckGo endpoint (and the browser Google scrape if the browser skill is on).
# All keys are optional — search still works with none of them set.
SEARCH_PROVIDER=auto
# Tavily (great for deep_research: returns answer + page content + images).
# TAVILY_API_KEY=
# Brave Search API (web + news + images).
# BRAVE_SEARCH_API_KEY=
# SerpAPI (Google web/news/images via API).
# SERPAPI_API_KEY=

# --- Voice (optional, ElevenLabs Text-to-Speech) ---
# Also settable from the dashboard under Settings → Credentials.
# The key also enables inbound WhatsApp voice transcription when voice_input.enabled is true.
# ELEVENLABS_API_KEY=

# --- Skill Configuration ---
# GitHub Token for the github skill
# GITHUB_TOKEN=your_github_token_here
